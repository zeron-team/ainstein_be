# =============================================================================
# AInstein EPC Suite — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Databases ---
SQL_URL=postgresql://epc_user:CHANGE_ME@localhost:5432/epc_db
MONGO_URL=mongodb://epc_user:CHANGE_ME@127.0.0.1:27017/epc?authSource=admin
REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRE_MINUTES=60

# --- Google Gemini AI ---
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-2.5-pro-preview-05-06
GEMINI_API_HOST=https://generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta

# --- CORS ---
# JSON array of allowed origins. Use HTTPS in production.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- File Uploads ---
HCE_UPLOAD_DIR=/tmp/hce_uploads

# --- Environment ---
# Set to "prod" in production to disable /docs and /redoc
ENV=dev

# --- Ainstein / Markey WS Integration ---
AINSTEIN_HTTP_METHOD=GET
AINSTEIN_API_URL=https://your-hce-endpoint.example.com/obtener
AINSTEIN_APP=AInstein
AINSTEIN_API_KEY=CHANGE_ME
AINSTEIN_TOKEN=CHANGE_ME
AINSTEIN_TIMEOUT_SECONDS=60

# --- Qdrant (Vector Database for RAG) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_ENABLED=true

# --- RAG Settings ---
RAG_ENABLED=true
RAG_FEW_SHOT_EXAMPLES=3
